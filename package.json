{
  "name": "pokeguide",
  "version": "1.0.1",
  "description": "Pokemon companion app",
  "main": "electron/main.js",
  "author": "R2D2 Games",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "dist": "vite build && electron-builder",
    "release": "vite build && electron-builder --publish always",
    "electron": "electron ."
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.0.12",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.pokeguide.app",
    "productName": "PokeGuide",
    "files": [
      "dist",
      "electron",
      "data",
      "public",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "scripts",
        "to": "scripts"
      }
    ],
    "directories": {
      "buildResources": "resources"
    },
    "win": {
      "icon": "resources/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "artifactName": "PokeGuide Installer.${ext}",
      "differentialPackage": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "LobbyxD",
        "repo": "pokeguide"
      }
    ]
  }
}
